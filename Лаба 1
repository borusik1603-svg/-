    15: "пятнадцать"
}

process_dict(test_dict)

# 6. Работа с прямоугольниками
print("Задание 6:")
def rectangle_task(lengths, widths):
    print("\n6) Работа с прямоугольниками")
    print("Длины:", lengths)
    print("Ширины:", widths)

    # вычисляем площади
    areas = []
    for l, w in zip(lengths, widths):
        area = l * w
        areas.append(area)
        print(f"Площадь прямоугольника {l} x {w} = {area}")

    # записываем площади в множество
    areas_set = set(areas)
    print("Множество площадей:", areas_set)

    # сортировка
    sorted_areas = sorted(areas_set)
    print("Отсортированные площади:", sorted_areas)

    # поиск медианы
    mid = len(sorted_areas) // 2
    if len(sorted_areas) % 2 == 0:
        median = (sorted_areas[mid - 1] + sorted_areas[mid]) / 2
    else:
        median = sorted_areas[mid]

    print("Медиана:", median)

    # фильтрация
    filtered_areas = list(filter(lambda x: x >= median, sorted_areas))
    print("Площади >= медианы:", filtered_areas)

    # итоговый расчёт
    result = sum(filtered_areas) / len(lengths)
    print("Итоговый результат:", result)

    return result


lengths = [5, 9, 6, 8]
widths = [2, 3, 5, 7]

rectangle_task(lengths, widths)
# 7. Генерация пароля
print("")
print("Задание 7:")
def generate_password(length, upper_count, special_count):
    print("\n7) Генерация пароля")
    print("Длина пароля:", length)
    print("Количество заглавных букв:", upper_count)
    print("Количество специальных символов:", special_count)

    password = []

    # заглавные буквы
    upper_letters = random.choices(string.ascii_uppercase, k=upper_count)
    print("Заглавные буквы:", upper_letters)
    password += upper_letters

    # специальные символы
    special_symbols = random.choices(string.punctuation, k=special_count)
    print("Специальные символы:", special_symbols)
    password += special_symbols

    # остальные символы
    remaining = length - upper_count - special_count
    other_symbols = random.choices(string.ascii_lowercase + string.digits, k=remaining)
    print("Остальные символы:", other_symbols)
    password += other_symbols

    # перемешивание
    random.shuffle(password)
    final_password = ''.join(password)

    print("Сгенерированный пароль:", final_password)
    return final_password


generate_password(10, 3, 2)
