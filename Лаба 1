# 5. Обработка словаря
print("Задание 5:")
def process_dict(input_dict):
    print("\n5) Обработка словаря")
    print("Исходный словарь:", input_dict)

    # поиск минимального и максимального ключа
    min_key = min(input_dict.keys())
    max_key = max(input_dict.keys())
    print("Минимальный ключ:", min_key)
    print("Максимальный ключ:", max_key)

    # вычисление среднего значения
    average = (min_key + max_key) / 2
    print("Среднее значение:", average)

    # фильтрация словаря
    filtered_dict = dict(
        filter(lambda item: item[0] >= average, input_dict.items())
    )

    print("Итоговый словарь после фильтрации:", filtered_dict)
    return filtered_dict


